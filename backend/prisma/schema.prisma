generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String  @id @default(uuid()) @db.Uuid
  email          String  @unique
  firstName      String  @default("")
  lastName       String?
  password       String
  username       String?
  publicKey      String
  privateKey     String
  privateKeyIv   String
  privateKeyTag  String
  encryptionSalt String
  plan           String  @default("free")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memories        Memory[]
  apiKeys         ApiKey[]
  archivedApiKeys ArchivedApiKey[]

  @@index([email])
}

model Memory {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @db.Uuid
  title    String?
  content  String
  summary  String
  vectorId String

  format          String @default("markdown")
  importanceScore Float  @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  memoryTags MemoryTag[]

  @@index([userId])
}

model MemoryTag {
  id       String @id @default(uuid()) @db.Uuid
  memoryId String @db.Uuid
  tag      String

  memory Memory @relation(fields: [memoryId], references: [id])

  @@index([memoryId])
}

model ApiKey {
  id     String  @id @default(uuid()) @db.Uuid
  name   String?
  key    String  @unique
  userId String  @db.Uuid
  prefix String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ArchivedApiKey {
  id     String  @id @default(uuid()) @db.Uuid
  name   String?
  userId String  @db.Uuid
  key    String  @unique
  prefix String

  archivedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
