generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id             String  @id @default(uuid()) @db.Uuid
  email          String  @unique
  firstName      String  @default("")
  lastName       String?
  password       String
  username       String?
  publicKey      String
  privateKey     String
  privateKeyIv   String
  privateKeyTag  String
  encryptionSalt String
  plan           String  @default("free")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memories        Memory[]
  apiKeys         ApiKey[]
  archivedApiKeys ArchivedApiKey[]

  @@index([email])
}

model Memory {
  id       String         @id @default(uuid()) @db.Uuid
  userId   String         @db.Uuid
  title    String?
  content  String
  summary  String
  category MemoryCategory @default(preferences)

  contentIv     String?
  contentTag    String?
  summaryIv     String?
  summaryTag    String?
  encryptionKey String?

  format          String @default("markdown")
  importanceScore Float  @default(0.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id])
  memoryTags MemoryTag[]
  embeddings MemoryEmbedding[]

  @@index([userId])
}

model MemoryEmbedding {
  id           String                      @id @default(uuid()) @db.Uuid
  memoryId     String                      @db.Uuid
  userId       String                      @db.Uuid
  contentChunk String
  chunkIv      String
  chunkTag     String
  embedding    Unsupported("vector(1536)")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MemoryTag {
  id       String @id @default(uuid()) @db.Uuid
  memoryId String @db.Uuid
  tag      String

  memory Memory @relation(fields: [memoryId], references: [id])

  @@index([memoryId])
}

model ApiKey {
  id     String  @id @default(uuid()) @db.Uuid
  name   String?
  key    String  @unique
  userId String  @db.Uuid
  prefix String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ArchivedApiKey {
  id     String  @id @default(uuid()) @db.Uuid
  name   String?
  userId String  @db.Uuid
  key    String  @unique
  prefix String

  archivedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum MemoryCategory {
  preferences
  identity
  projects
  expertise
  ideas
  relationships
  constraints
  goals
}
